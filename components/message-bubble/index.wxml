<!-- Flat thread-style message (no bubbles, Slack/Discord inspired) -->
<view
  id="message-{{message.id}}"
  class="msg-row {{isActive ? 'msg-row--active' : ''}}"
  style="animation-delay: {{delay}}ms;"
  bindtap="handleBubbleTap"
  bindlongpress="handleLongPress"
>
  <!-- Avatar column -->
  <view class="msg-avatar-col">
    <view wx:if="{{!grouped}}" class="msg-avatar {{message.sender === 'user' ? 'msg-avatar--user' : 'msg-avatar--ai'}}">
      <text class="msg-avatar__text">{{message.sender === 'user' ? '👤' : agentEmoji}}</text>
    </view>
    <text wx:else class="msg-hover-time">{{message.formattedTime}}</text>
  </view>

  <!-- Content column -->
  <view class="msg-body">
    <!-- Header (only for first in group) -->
    <view wx:if="{{!grouped}}" class="msg-header">
      <text class="msg-sender {{message.sender === 'user' ? 'msg-sender--user' : 'msg-sender--ai'}}">{{message.sender === 'user' ? '我' : (agentName || '对方')}}</text>
      <text class="msg-time">{{message.formattedTime}}</text>
      <text wx:if="{{message.sender !== 'user' && message.model}}" class="msg-model">{{message.model}}</text>
    </view>

    <!-- Inline reply reference -->
    <view wx:if="{{message.replyTo && replyToText}}" class="msg-reply-ref">
      <text class="msg-reply-ref__icon">↩</text>
      <text class="msg-reply-ref__text">{{replyToText}}</text>
    </view>

    <!-- User: plain text -->
    <text wx:if="{{message.sender === 'user' && !message.mediaType}}" class="msg-text" user-select>{{message.text}}</text>

    <!-- User: image -->
    <image wx:elif="{{message.sender === 'user' && message.mediaType === 'image'}}" src="{{message.mediaUrl}}" class="msg-image" mode="widthFix" />

    <!-- User: voice -->
    <text wx:elif="{{message.sender === 'user' && message.mediaType === 'voice'}}" class="msg-text">🎙️ 语音消息</text>

    <!-- User: other -->
    <text wx:elif="{{message.sender === 'user'}}" class="msg-text" user-select>{{message.text}}</text>

    <!-- AI: markdown rendered -->
    <view wx:else class="md-content">
      <block wx:for="{{mdNodes}}" wx:key="index">
        <view wx:if="{{item.type === 'paragraph'}}" class="md-p">
          <block wx:for="{{item.segments}}" wx:for-item="seg" wx:key="index">
            <text wx:if="{{seg.type === 'text'}}" class="md-text">{{seg.text}}</text>
            <text wx:elif="{{seg.type === 'bold'}}" class="md-bold">{{seg.text}}</text>
            <text wx:elif="{{seg.type === 'code'}}" class="md-inline-code">{{seg.text}}</text>
            <text wx:elif="{{seg.type === 'link'}}" class="md-link" data-href="{{seg.href}}" bindtap="handleLinkTap">{{seg.text}}</text>
          </block>
        </view>

        <view wx:elif="{{item.type === 'heading'}}" class="md-h md-h--{{item.level}}">
          <block wx:for="{{item.segments}}" wx:for-item="seg" wx:key="index">
            <text wx:if="{{seg.type === 'text'}}" class="md-text">{{seg.text}}</text>
            <text wx:elif="{{seg.type === 'bold'}}" class="md-bold">{{seg.text}}</text>
            <text wx:elif="{{seg.type === 'code'}}" class="md-inline-code">{{seg.text}}</text>
          </block>
        </view>

        <view wx:elif="{{item.type === 'codeblock'}}" class="md-codeblock">
          <text wx:if="{{item.lang}}" class="md-codeblock__lang">{{item.lang}}</text>
          <scroll-view scroll-x class="md-codeblock__scroll">
            <text class="md-codeblock__text" user-select>{{item.text}}</text>
          </scroll-view>
        </view>

        <view wx:elif="{{item.type === 'ul'}}" class="md-list">
          <view wx:for="{{item.items}}" wx:for-item="li" wx:key="index" class="md-list-item">
            <text class="md-list-bullet">•</text>
            <view class="md-list-content">
              <block wx:for="{{li.segments}}" wx:for-item="seg" wx:key="index">
                <text wx:if="{{seg.type === 'text'}}" class="md-text">{{seg.text}}</text>
                <text wx:elif="{{seg.type === 'bold'}}" class="md-bold">{{seg.text}}</text>
                <text wx:elif="{{seg.type === 'code'}}" class="md-inline-code">{{seg.text}}</text>
              </block>
            </view>
          </view>
        </view>

        <view wx:elif="{{item.type === 'ol'}}" class="md-list">
          <view wx:for="{{item.items}}" wx:for-item="li" wx:key="index" class="md-list-item">
            <text class="md-list-bullet">{{index + 1}}.</text>
            <view class="md-list-content">
              <block wx:for="{{li.segments}}" wx:for-item="seg" wx:key="index">
                <text wx:if="{{seg.type === 'text'}}" class="md-text">{{seg.text}}</text>
                <text wx:elif="{{seg.type === 'bold'}}" class="md-bold">{{seg.text}}</text>
                <text wx:elif="{{seg.type === 'code'}}" class="md-inline-code">{{seg.text}}</text>
              </block>
            </view>
          </view>
        </view>

        <view wx:elif="{{item.type === 'blockquote'}}" class="md-blockquote">
          <block wx:for="{{item.segments}}" wx:for-item="seg" wx:key="index">
            <text wx:if="{{seg.type === 'text'}}" class="md-text">{{seg.text}}</text>
            <text wx:elif="{{seg.type === 'bold'}}" class="md-bold">{{seg.text}}</text>
          </block>
        </view>

        <view wx:elif="{{item.type === 'hr'}}" class="md-hr"></view>
      </block>
    </view>

    <!-- Delivery status (only show failed state for retry) -->
    <view wx:if="{{message.sender === 'user' && message.deliveryStatus === 'failed'}}" class="msg-delivery">
      <text class="msg-delivery__icon msg-delivery--failed" catchtap="onRetryTap" data-msg-id="{{message.id}}">✕ 重试</text>
    </view>

    <!-- Reactions -->
    <view wx:if="{{message.reactions && message.reactions.length}}" class="msg-reactions">
      <view wx:for="{{message.reactions}}" wx:key="*this" class="msg-reaction" bindtap="handleReactionTap" hover-class="msg-reaction--pressed">
        <text class="msg-reaction__emoji">{{item}}</text>
      </view>
    </view>

    <!-- Actions row (on active) -->
    <view wx:if="{{isActive}}" class="msg-actions">
      <view class="msg-action" bindtap="handleReplyTap" hover-class="msg-action--pressed">
        <text class="msg-action__icon">↩</text>
      </view>
      <view class="msg-action" bindtap="handleReactionTap" hover-class="msg-action--pressed">
        <oc-icon name="smile-plus" tone="dark" size="28rpx" />
      </view>
      <view wx:if="{{message.sender === 'user'}}" class="msg-action" bindtap="handleEditTap" hover-class="msg-action--pressed">
        <text class="msg-action__icon">✎</text>
      </view>
      <view class="msg-action msg-action--danger" bindtap="handleDeleteTap" hover-class="msg-action--pressed">
        <text class="msg-action__icon">🗑</text>
      </view>
    </view>
  </view>
</view>
