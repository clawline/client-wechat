@import "../../theme/tokens.wxss";

/* ── Flat thread-style message row ── */
.msg-row {
  display: flex;
  gap: 16rpx;
  padding: 6rpx 24rpx;
  border-radius: 12rpx;
  animation: msgIn 0.2s ease both;
}

.msg-row--active {
  background: rgba(0, 0, 0, 0.03);
}

/* Avatar column */
.msg-avatar-col {
  width: 56rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.msg-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.msg-avatar--user {
  background: linear-gradient(135deg, #5B8DEF, #7C6AEF);
}

.msg-avatar--ai {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-deep));
  box-shadow: 0 8rpx 16rpx rgba(103, 184, 139, 0.15);
}

.msg-avatar__text {
  font-size: 22rpx;
}

.msg-hover-time {
  font-size: 18rpx;
  color: var(--color-text-muted);
  opacity: 0;
  text-align: center;
  display: block;
  line-height: 56rpx;
}

.msg-row--active .msg-hover-time {
  opacity: 0.5;
}

/* Content body */
.msg-body {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

/* Header row */
.msg-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 4rpx;
  flex-wrap: wrap;
}

.msg-sender {
  font-size: 28rpx;
  font-weight: 700;
}

.msg-sender--user {
  color: #5B8DEF;
}

.msg-sender--ai {
  color: var(--color-primary);
}

.msg-time {
  font-size: 20rpx;
  color: var(--color-text-muted);
  opacity: 0.4;
}

.msg-model {
  font-size: 18rpx;
  color: var(--color-text-muted);
  opacity: 0.45;
  background: rgba(0, 0, 0, 0.04);
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}

/* Inline reply reference */
.msg-reply-ref {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 4rpx;
}

.msg-reply-ref__icon {
  font-size: 20rpx;
  color: var(--color-text-muted);
  opacity: 0.5;
}

.msg-reply-ref__text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  opacity: 0.6;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

/* Message text — no bubble, just text */
.msg-text {
  font-size: 30rpx;
  line-height: 1.55;
  color: var(--color-text-primary);
  word-break: break-word;
}

.msg-image {
  max-width: 400rpx;
  border-radius: 12rpx;
  margin-top: 4rpx;
}

/* Delivery status */
.msg-delivery {
  margin-top: 2rpx;
}

.msg-delivery__icon {
  font-size: 20rpx;
}

.msg-delivery--failed { color: #E53E3E; }

/* Reactions */
.msg-reactions {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}

.msg-reaction {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
}

.msg-reaction--pressed { transform: scale(0.94); }

.msg-reaction__emoji { font-size: 24rpx; }

/* Actions row */
.msg-actions {
  display: flex;
  gap: 8rpx;
  margin-top: 6rpx;
}

.msg-action {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.msg-action--pressed { transform: scale(0.92); }

.msg-action__icon { font-size: 22rpx; }

.msg-action--danger .msg-action__icon { font-size: 20rpx; }

@keyframes msgIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Markdown styles ── */
.md-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.md-p { line-height: 1.6; }

.md-text {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.md-bold {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.md-inline-code {
  font-size: 26rpx;
  background: var(--color-border);
  color: var(--color-text-primary);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-family: Menlo, Monaco, Consolas, monospace;
}

.md-link {
  font-size: 30rpx;
  color: var(--color-blue);
  text-decoration: underline;
}

.md-h { line-height: 1.4; margin-bottom: 4rpx; }
.md-h--1 { font-size: 38rpx; font-weight: 700; }
.md-h--2 { font-size: 34rpx; font-weight: 700; }
.md-h--3 { font-size: 30rpx; font-weight: 600; }

.md-codeblock {
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-16);
  padding: 16rpx 20rpx;
  margin: 8rpx 0;
  position: relative;
}

.md-codeblock__lang {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.md-codeblock__scroll { width: 100%; white-space: nowrap; }

.md-codeblock__text {
  font-size: 24rpx;
  font-family: Menlo, Monaco, Consolas, monospace;
  color: var(--color-text-primary);
  line-height: 1.5;
  white-space: pre;
}

.md-list { margin: 4rpx 0; }

.md-list-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.md-list-bullet {
  font-size: 30rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  width: 28rpx;
  text-align: center;
}

.md-list-content { flex: 1; line-height: 1.6; }

.md-blockquote {
  border-left: 4rpx solid var(--color-primary);
  padding-left: 16rpx;
  margin: 8rpx 0;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.md-hr {
  height: 2rpx;
  background: var(--color-border);
  margin: 16rpx 0;
}
