@import "../../theme/page-shell.wxss";

/* ── Header Actions ── */
.agent-header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.agent-refresh-icon {
  font-size: 32rpx;
  font-weight: 600;
}

.agent-view-icon {
  font-size: 32rpx;
}

/* ── Loading / Empty ── */
.agent-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.agent-loading__text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 12rpx;
}

.empty-state__icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.empty-state__title {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.empty-state__desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ── Server Groups ── */
.agent-groups {
  padding: 8rpx 0 32rpx;
}

/* ── Server Section Header ── */
.server-section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx 12rpx;
}

.server-section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
}

.server-section-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  letter-spacing: 1rpx;
}

.server-section-count {
  font-size: 22rpx;
  color: var(--color-text-muted);
  background: rgba(0, 0, 0, 0.05);
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  margin-left: auto;
}

/* ── Grid View ── */
.agent-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 12rpx 24rpx 20rpx;
}

.agent-grid-card {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 12rpx 20rpx;
  border-radius: var(--radius-20);
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  animation: cardIn 0.25s ease both;
  position: relative;
}

.agent-grid-card--pressed {
  transform: scale(0.95);
  opacity: 0.85;
}

.agent-grid-card__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, var(--color-primary), var(--color-primary-deep));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(103, 184, 139, 0.18);
}

.agent-grid-card__emoji {
  font-size: 36rpx;
}

.agent-grid-card__name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  padding: 0 4rpx;
}

.agent-grid-card__badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  background: var(--color-primary);
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  line-height: 1.4;
}

/* ── List View ── */
.agent-list-section {
  padding: 4rpx 24rpx;
}

.agent-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 20rpx;
  background: var(--color-card);
  border-radius: var(--radius-20);
  border: 2rpx solid rgba(237, 242, 240, 0.5);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 12rpx;
  animation: cardFadeIn 0.3s ease both;
}

.agent-card--pressed {
  transform: scale(0.98);
  opacity: 0.85;
}

.agent-card__avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #67B88B, #4A9A70);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(103, 184, 139, 0.15);
}

.agent-card__emoji {
  font-size: 40rpx;
}

.agent-card__body {
  flex: 1;
  min-width: 0;
}

.agent-card__head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.agent-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.agent-card__badge {
  font-size: 20rpx;
  background: rgba(103, 184, 139, 0.12);
  color: var(--color-primary);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-pill);
  font-weight: 500;
}

.agent-card__model {
  font-size: 24rpx;
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── Animations ── */
@keyframes cardIn {
  from { opacity: 0; transform: scale(0.92) translateY(12rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
