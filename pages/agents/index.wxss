@import "../../theme/page-shell.wxss";

.agent-server-badge {
  background: rgba(103, 184, 139, 0.12);
  border-radius: var(--radius-pill);
  padding: 6rpx 16rpx;
}

.agent-header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.agent-refresh-icon {
  font-size: 28rpx;
}

.agent-server-badge__text {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.agent-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.agent-loading__text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.empty-state__title {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-state__desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.agent-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-24);
  border: 2rpx solid rgba(237, 242, 240, 0.5);
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
  animation: cardFadeIn 0.3s ease both;
}

.agent-card--pressed {
  transform: scale(0.98);
  opacity: 0.9;
}

.agent-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #67B88B, #4A9A70);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(103, 184, 139, 0.2);
}

.agent-card__emoji {
  font-size: 44rpx;
}

.agent-card__body {
  flex: 1;
  min-width: 0;
}

.agent-card__head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.agent-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.agent-card__badge {
  font-size: 20rpx;
  background: var(--color-border);
  color: var(--color-text-secondary);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-pill);
}

.agent-card__model {
  font-size: 24rpx;
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Grid view ── */
.agent-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.agent-grid-card {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 8rpx;
  border-radius: var(--radius-20);
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  animation: cardIn 0.25s ease both;
  position: relative;
}

.agent-grid-card--pressed {
  transform: scale(0.95);
  opacity: 0.9;
}

.agent-grid-card__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-deep));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(103, 184, 139, 0.18);
}

.agent-grid-card__emoji {
  font-size: 36rpx;
}

.agent-grid-card__name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.agent-grid-card__badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  background: var(--color-primary);
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
}

.agent-view-icon {
  font-size: 28rpx;
}

@keyframes cardIn {
  from { opacity: 0; transform: scale(0.9) translateY(12rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

/* Server name tag */
.agent-grid-card__server {
  font-size: 18rpx;
  color: var(--color-text-muted);
  opacity: 0.6;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.agent-card__server {
  font-size: 20rpx;
  color: var(--color-text-muted);
  opacity: 0.5;
  background: rgba(0, 0, 0, 0.04);
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  margin-left: 8rpx;
}
