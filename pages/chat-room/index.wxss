@import "../../theme/page-shell.wxss";

.disconnect-banner {
  margin: 0 16rpx 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
}

.disconnect-banner--offline {
  background: #FFF2F0;
  color: #D64545;
  border: 2rpx solid #FFD1CC;
}

.disconnect-banner--reconnecting {
  background: #FFF8E8;
  color: #B7791F;
  border: 2rpx solid #F7D58C;
}

.disconnect-banner__text {
  font-size: 24rpx;
  font-weight: 600;
}

.error-toast {
  margin: 0 16rpx 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #fff2f0;
  border: 2rpx solid #ffd1cc;
}

.error-toast__title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #d64545;
}

.error-toast__body {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #d64545;
}

.action-card {
  margin: 8rpx 16rpx 16rpx 76rpx;
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-16);
  padding: 20rpx;
}

.action-card__title {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.action-card__options {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.action-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-pill);
}

.action-chip__label {
  font-size: 24rpx;
}

.date-separator {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 20rpx 16rpx;
}

.date-separator__line {
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.date-separator__text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

.suggestion-bar {
  white-space: nowrap;
  padding: 8rpx 16rpx 12rpx;
}

.suggestion-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  margin-right: 10rpx;
  border-radius: 999rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
}

.suggestion-pill--follow {
  background: #FFF8E8;
  border-color: #F7D58C;
}

.suggestion-pill__text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.reply-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  margin: 0 16rpx 8rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-16);
}

.reply-bar__indicator,
.edit-bar__indicator {
  width: 6rpx;
  height: 48rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.reply-bar__indicator { background: var(--color-blue); }
.edit-bar__indicator { background: var(--color-primary); }

.reply-bar__content,
.edit-bar__content {
  flex: 1;
  min-width: 0;
}

.reply-bar__label,
.edit-bar__label {
  display: block;
  font-size: 20rpx;
  font-weight: 500;
}

.reply-bar__label { color: var(--color-blue); }
.edit-bar__label { color: var(--color-primary); }

.reply-bar__text,
.edit-bar__text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reply-bar__close,
.edit-bar__close {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding: 8rpx;
  flex-shrink: 0;
}

.edit-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  margin: 0 16rpx 8rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-16);
}

.chat-media-icon {
  font-size: 36rpx;
  line-height: 1;
}

.chat-send--recording {
  background: #E15B64 !important;
}

.typing-indicator-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 8rpx 16rpx 16rpx;
}

.typing-indicator-bubble {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-16);
}

.typing-indicator-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-style: italic;
}
